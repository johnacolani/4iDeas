rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email in [
          'john.ace.colani@outlook.com'
        ];
    }

    match /orders/{orderId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /portfolio_apps/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /portfolio_case_studies/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /portfolio_publications/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /portfolio_open_source/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /site_services/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /contact_entries/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
